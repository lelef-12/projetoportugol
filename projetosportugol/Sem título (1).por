programa {
  funcao inicio() {
    inteiro menor, idade
    escreva("informe sua idade: ")
    leia(idade)

    se(idade <18) {
      escreva("você é menor de idade. fala fala ai menor!!!")
    }senao{
      
      escreva("Você é maior de idade.")
    }

    escreva("\n") // comando para quebrar linha
    
  }
}
